# Figma API Configuration
# Get your personal access token from: https://help.figma.com/hc/en-us/articles/8085703771159-Manage-personal-access-tokens
FIGMA_API_KEY=your_figma_personal_access_token_here

# Alternative: OAuth Bearer Token (if using OAuth instead of personal access token)
# FIGMA_OAUTH_TOKEN=your_oauth_bearer_token_here

# Server Configuration
PORT=3000

# Output format for tool responses (yaml or json)
OUTPUT_FORMAT=yaml

# Skip image downloads (true/false)
# Set to true to disable the download_figma_images tool
SKIP_IMAGE_DOWNLOADS=false

# Node Environment
NODE_ENV=production